{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "sourceMap": false,
    "declarationMap": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    ".worktrees",
    "test/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "vitest.config.ts",
    "eslint.config.js"
  ]
}
